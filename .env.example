# Agent Xi 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# LLM Provider 选择: "deepseek" | "claude"
AGENT_XI_LLM_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key-here
AGENT_XI_LLM_MODEL=deepseek-chat
AGENT_XI_LLM_BASE_URL=https://api.deepseek.com

# Claude API (可选，切换 provider 时使用)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# AGENT_XI_LLM_MODEL=claude-sonnet-4-20250514
# AGENT_XI_LLM_BASE_URL=https://api.anthropic.com

# 应用配置
# AGENT_XI_DEBUG=false
# AGENT_XI_MAX_HISTORY_TURNS=50

# Web 访问密码（设置后访问 UI 需先输密码，留空则不鉴权）
# XI_ACCESS_PASSWORD=your-password-here
